# kitty-ping-panel — add these to your kitty.conf
# See: https://github.com/your-user/kitty-ping-panel

# Use custom tab bar (required)
tab_bar_style custom

# Powerline round separators (optional, but looks nice)
tab_powerline_style round

# Tab bar at the bottom
tab_bar_edge bottom

# Show tab bar even with a single tab (so you always see the status)
tab_bar_min_tabs 1
