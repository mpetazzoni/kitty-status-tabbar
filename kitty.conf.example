# kitty-status-tabbar — add these to your kitty.conf
# See: https://github.com/mpetazzoni/kitty-status-tabbar

# Use custom tab bar (required)
tab_bar_style custom

# Powerline separator style (optional — works with slanted, round, or angled)
tab_powerline_style slanted

# Tab bar at the bottom
tab_bar_edge bottom

# Show tab bar even with a single tab (so you always see the status)
tab_bar_min_tabs 1
